{
  "name": "@sitecore-jss/sitecore-jss-dev-tools",
  "version": "22.9.0-canary.18",
  "description": "Utilities to assist in the development and deployment of Sitecore JSS apps.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "sideEffects": false,
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json && tsc -p tsconfig-esm.json",
    "watch": "npm run build -- --watch",
    "clean": "del-cli dist types",
    "lint": "eslint \"./src/**/*.ts\"",
    "test": "mocha --require ts-node/register -r tsconfig-paths/register  \"./src/**/*.test.ts\"",
    "prepublishOnly": "npm run build",
    "coverage": "nyc npm test",
    "generate-docs": "npx typedoc --plugin typedoc-plugin-markdown --outputFileStrategy Members --parametersFormat table --readme none --out ../../ref-docs/sitecore-jss-dev-tools src/index.ts --githubPages false"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "scjss-deploy": "./dist/cjs/bin/deploy.js",
    "scjss-verify-setup": "./dist/cjs/bin/verify-setup.js"
  },
  "author": {
    "name": "Sitecore Corporation",
    "url": "https://jss.sitecore.com"
  },
  "license": "Apache-2.0",
  "homepage": "https://jss.sitecore.com",
  "bugs": {
    "url": "https://github.com/sitecore/jss/issues"
  },
  "dependencies": {
    "@babel/parser": "^7.28.0",
    "@sitecore-jss/sitecore-jss": "22.9.0-canary.18",
    "chalk": "^4.1.2",
    "chokidar": "^4.0.3",
    "del": "^6.0.0",
    "express": "^5.1.0",
    "form-data": "^4.0.4",
    "fs-extra": "^11.3.1",
    "glob": "^10.4.5",
    "import-fresh": "^3.3.1",
    "joi": "^18.0.0",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "module-alias": "^2.2.3",
    "readline-sync": "^1.4.10",
    "recast": "^0.23.11",
    "resolve": "^1.22.10",
    "ts-node": "^10.9.2",
    "url-join": "^4.0.1",
    "uuid": "^11.1.0",
    "yargs": "^17.6.2"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/register": "^7.27.1",
    "@types/chai": "^4.3.4",
    "@types/del": "^4.0.0",
    "@types/express": "^5.0.3",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.1",
    "@types/node": "^22.9.0",
    "@types/readline-sync": "^1.4.8",
    "@types/resolve": "^1.20.2",
    "@types/sinon": "^17.0.4",
    "@types/url-join": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "@types/yargs": "^17.0.22",
    "chai": "^4.3.7",
    "cross-env": "^7.0.3",
    "del-cli": "^6.0.0",
    "eslint": "^8.56.0",
    "mocha": "^10.2.0",
    "nock": "^13.0.0",
    "nyc": "^17.1.0",
    "sinon": "^20.0.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.9.2"
  },
  "types": "types/index.d.ts",
  "gitHead": "2f4820efddf4454eeee58ed1b2cc251969efdf5b",
  "files": [
    "dist",
    "types",
    "/*.js",
    "/*.d.ts"
  ]
}
